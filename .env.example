# Get these from https://console.cloud.google.com
# 1. Create a project
# 2. Enable "Gmail API"
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add authorized redirect URI: http://localhost:3000/auth/google/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Any random long string, used to encrypt the session cookie
SESSION_SECRET=

PORT=3000

# ── Foundry IQ (Azure AI Foundry) — required for Microsoft IQ integration ──
# Get these from https://ai.azure.com (Azure AI Foundry)
# 1. Create an Azure AI Foundry resource / project
# 2. Deploy a model (e.g. gpt-4o)
# 3. Copy the endpoint and key from the resource's "Keys and Endpoint" page
AZURE_FOUNDRY_ENDPOINT=https://your-resource.openai.azure.com
AZURE_FOUNDRY_KEY=your-azure-key-here
AZURE_FOUNDRY_DEPLOYMENT=gpt-4o


# ── Microsoft Work IQ (3 AI Agents) ──
# Free setup at https://portal.azure.com → App registrations
# Add redirect URI: http://localhost:3000/auth/workiq/callback
# Add permission: Microsoft Graph → Mail.Read (Delegated)
WORKIQ_CLIENT_ID=your-microsoft-app-client-id
WORKIQ_CLIENT_SECRET=your-microsoft-app-client-secret
WORKIQ_REDIRECT_URI=http://localhost:3000/auth/workiq/callback
